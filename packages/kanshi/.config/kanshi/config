# --- 1. Профіль для роботи лише з ноутбуком ---
profile laptop_only {
    output eDP-1 enable scale 2.0
}

# --- 2. Профіль для роботи з зовнішнім монітором ---
profile docked {
    output eDP-1 disable
    output DP-1 enable scale 1.333333
    
    # Виправлена команда (без літери 's' у слові workspace)
    exec hyprctl dispatch moveworkspacetomonitor 1 DP-3
}
