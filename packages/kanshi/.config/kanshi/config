# --- 1. Визначення моніторів та їх аліасів ---
# Це центральне місце для налаштування ваших екранів.

# Вбудований монітор ноутбука (HiDPI)
output "eDP-1" {
  # Вказуємо параметри за замовчуванням для цього монітора
  scale 2.0
  # Даємо йому зручне ім'я (аліас)
  alias $INTERNAL_SCREEN
}

# Ваш зовнішній 2K монітор
output "DP-1" {
  # Вказуємо параметри за замовчуванням для цього монітора
  scale 1.25
  # Даємо йому зручне ім'я (аліас)
  alias $EXTERNAL_SCREEN
}


# --- 2. Профілі, що використовують аліаси ---
# Тепер профілі стають дуже чистими і читабельними.

# Профіль для роботи лише з ноутбуком
profile laptop_only {
  # Активується, коли підключено ЛИШЕ $INTERNAL_SCREEN
  output $INTERNAL_SCREEN enable
}

# Профіль для роботи з зовнішнім монітором (ноутбук закритий)
profile docked {
  # Активується, коли підключені ОБИДВА монітори
  output $EXTERNAL_SCREEN enable
  output $INTERNAL_SCREEN disable
  
  # ДОДАТКОВА КОМАНДА: Перемістити всі робочі столи на активний монітор
  # Це вирішує проблему "втрачених" робочих столів на вимкненому екрані
  exec hyprctl dispatch moveworkspacestomonitor "1 $EXTERNAL_SCREEN"
}
